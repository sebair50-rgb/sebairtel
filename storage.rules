rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match any file in the 'avatars' folder
    match /avatars/{userId}/{allPaths=**} {
      // Allow read access to anyone (for public profile pictures)
      allow read;
      // Allow write access (create, update, delete) only if the user is authenticated
      // and the userId in the path matches their own UID.
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Match any file in the 'cvs' folder
    match /cvs/{userId}/{allPaths=**} {
      // Allow read access only if the user is authenticated.
      // This keeps CVs private unless you are logged in.
      allow read: if request.auth != null;
      // Allow write access (create, update, delete) only if the user is authenticated
      // and the userId in the path matches their own UID.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
