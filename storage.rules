rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user avatars
    // Allow anyone to read avatars.
    // Allow authenticated users to write to their own avatar directory.
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for user CVs
    // Allow anyone to read CVs.
    // Allow authenticated users to write to their own CV directory.
    match /cvs/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
