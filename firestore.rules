
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow creation and comprehensive updates by the owner
      allow create, update: if isOwner(userId);
      
      // Allow friends to update specific fields for friend requests
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendRequestsReceived', 'friendRequestsSent', 'friends']);
      
      match /notifications/{notifId} {
        allow read, delete: if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      }

      match /{subcollection}/{docId} {
          allow read, write: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']));
    }

    match /chats/{chatId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /news/{newsId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /market_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /stores/{storeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
