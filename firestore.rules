
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      
      // Allow user to create/update their own document fully
      allow create: if isOwner(userId);
      
      // Allow updates to own profile, OR allow other users to modify ONLY friend request arrays
      allow update: if isOwner(userId) || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendRequestsReceived', 'friendRequestsSent', 'friends'])
      );
      
      match /notifications/{notifId} {
        // Users can read and delete their own notifications
        allow read, delete: if isOwner(userId);
        // Any signed-in user can create a notification for another user (e.g. friend request alert)
        allow create: if isSignedIn();
        // Only owner can mark as read
        allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      }

      match /{subcollection}/{docId} {
          allow read, write: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']));
    }

    match /chats/{chatId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
